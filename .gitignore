# zsh runtime
*.zcompdump*
*.zwc
.DS_Store

# nvim runtime / plugin state (config is tracked; runtime is not)
config/nvim/.netrwhist
config/nvim/lazy-lock.json.bak

# tmux plugins installed by TPM (they land under the symlinked config dir)
config/tmux/plugins/

# gazelle runtime (theme.toml is tracked; the app-saved theme selection is not)
config/gazelle/config.json

# backups created by install.sh
.bigb-config-backup-*/

# chromium-generated theme cache (manifest.json etc. are tracked; the cache is not)
chromium/ethereal-theme/Cached Theme.pak
config/quickshell/.qmlls.ini
