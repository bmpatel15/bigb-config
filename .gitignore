# zsh runtime
*.zcompdump*
*.zwc
.DS_Store

# nvim runtime / plugin state (config is tracked; runtime is not)
config/nvim/.netrwhist
config/nvim/lazy-lock.json.bak

# tmux plugins installed by TPM (they land under the symlinked config dir)
config/tmux/plugins/

# backups created by install.sh
.bigb-config-backup-*/
