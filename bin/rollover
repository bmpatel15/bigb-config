#!/usr/bin/env bash
# rollover: carry unfinished tasks from the most recent daily note (before today)
# into today's ## Tasks. Each rolled task is appended to today via `ot`, and the
# source line is demoted to a struck-through bullet "- ~~<text>~~ → [[<today>]]"
# so it isn't counted twice and Obsidian's Tasks plugin can't re-toggle it into
# a corrupt checkbox. Re-running is a no-op. Only checkboxes with actual text
# roll forward; empty "- [ ]" placeholders are left alone.
set -euo pipefail

VAULT="${PKM:-$HOME/Documents/BigB-PKM}"
DIR="$VAULT/01 - Daily Notes"
SELF_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"

TODAY="$(date +%F)"

# Guard against the classic "forgot vpull" footgun: rolling over a stale vault
# re-surfaces tasks another machine already finished. If the vault tracks a
# reachable upstream and is behind it, refuse and point at vpull. Offline or
# no-upstream vaults skip the check silently so local work is never blocked.
if git -C "$VAULT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
	if git -C "$VAULT" fetch --quiet 2>/dev/null; then
		behind="$(git -C "$VAULT" rev-list --count 'HEAD..@{u}' 2>/dev/null || echo 0)"
		if [[ "${behind:-0}" -gt 0 ]]; then
			up="$(git -C "$VAULT" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)"
			echo "rollover: vault is $behind commit(s) behind $up." >&2
			echo "         Run  vpull  first, then re-run rollover." >&2
			exit 1
		fi
	fi
fi

# Most recent daily note strictly before today (ISO filenames sort chronologically).
PREV=""
for f in "$DIR"/*.md; do
	[[ -e "$f" ]] || continue
	base="$(basename "$f" .md)"
	[[ "$base" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]] || continue
	[[ "$base" < "$TODAY" ]] || continue
	if [[ -z "$PREV" || "$base" > "$PREV" ]]; then PREV="$base"; fi
done

if [[ -z "$PREV" ]]; then
	echo "rollover: no earlier daily note found; nothing to roll over."
	exit 0
fi
PREVFILE="$DIR/$PREV.md"

# Open tasks that actually have text.
mapfile -t OPEN < <(grep -nE '^[[:space:]]*- \[ \][[:space:]]+[^[:space:]]' "$PREVFILE" || true)
if [[ ${#OPEN[@]} -eq 0 ]]; then
	echo "rollover: no unfinished tasks in $PREV."
	exit 0
fi

# Ensure today exists before appending.
"$SELF_DIR/today-note" >/dev/null

count=0
for entry in "${OPEN[@]}"; do
	text="$(sed -E 's/^[0-9]+:[[:space:]]*- \[ \][[:space:]]+//' <<<"$entry")"
	"$SELF_DIR/ot" "$text"
	count=$((count + 1))
done

# Mark the source lines done and point them at today.
tmp="$(mktemp)"
TODAY="$TODAY" awk '
/^[[:space:]]*- \[ \][[:space:]]+[^[:space:]]/ {
	match($0, /^[[:space:]]*/); indent = substr($0, 1, RLENGTH)
	rest = substr($0, RLENGTH + 1)          # "- [ ] X"
	sub(/^- \[ \][[:space:]]+/, "", rest)   # "X"
	print indent "- ~~" rest "~~ → [[" ENVIRON["TODAY"] "]]"
	next
}
{ print }
' "$PREVFILE" >"$tmp"
cat "$tmp" >"$PREVFILE"
rm -f "$tmp"

echo "rollover: moved $count task(s) from $PREV → $TODAY."
