#!/usr/bin/env bash
# Launch the Obsidian Quick Capture popup: a dedicated Ghostty window (own
# Wayland app-id) running obsidian-capture. Hyprland floats/centers it via the
# float-quick-capture window rule keyed on this class.
set -euo pipefail

CLASS="com.ethereal.QuickCapture"

# Double-press = refocus the existing capture window (no second nvim on the same file).
# Lua-config Hyprland: hyprctl dispatch args are evaluated as Lua, not classic syntax.
if hyprctl clients 2>/dev/null | grep -qE "^[[:space:]]*class: ${CLASS//./\\.}$"; then
	hyprctl dispatch "hl.dsp.focus({ window = \"class:$CLASS\" })" >/dev/null
	exit 0
fi

# Deliberately more transparent than config/ghostty/config's 0.85: this is a
# transient capture popup, so it reads better as frosted glass floating over the
# wallpaper than as another solid terminal. Hyprland's global blur (hyprland.lua
# decoration.blur) does the frosting; this value controls how much wallpaper
# reaches it. Push it back toward 1.0 and the blur disappears — at 0.95 there is
# only 5% of backdrop left to blur and the window reads as a flat opaque panel.
exec ghostty \
	--class="$CLASS" \
	--title="Obsidian Quick Capture" \
	--gtk-single-instance=false \
	--background-opacity=0.78 \
	-e "$HOME/.local/bin/obsidian-capture"
