#!/usr/bin/env bash
# ot "task text": add a task under today's ## Tasks heading. Creates today's
# daily note first (via today-note) if needed, then inserts "- [ ] <task>" after
# the existing tasks, before the next ## heading. If there is no ## Tasks
# heading, appends one at the end of the file.
set -euo pipefail

VAULT="${PKM:-$HOME/Documents/BigB-PKM}"
SELF_DIR="$(cd -- "$(dirname -- "$0")" && pwd)"

if [[ $# -eq 0 ]]; then
	echo "usage: ot <task text>" >&2
	exit 1
fi
TASK="$*"

FILE="$("$SELF_DIR/today-note")"

tmp="$(mktemp)"
TASKLINE="- [ ] $TASK" awk '
{ lines[NR] = $0 }
END {
	line = ENVIRON["TASKLINE"]; n = NR; ti = 0
	for (i = 1; i <= n; i++) if (lines[i] ~ /^## Tasks[[:space:]]*$/) { ti = i; break }
	if (ti == 0) {
		for (i = 1; i <= n; i++) print lines[i]
		if (n > 0 && lines[n] !~ /^[[:space:]]*$/) print ""
		print "## Tasks"; print line
		exit
	}
	end = n
	for (i = ti + 1; i <= n; i++) if (lines[i] ~ /^## /) { end = i - 1; break }
	ins = ti
	for (i = ti + 1; i <= end; i++) if (lines[i] ~ /[^[:space:]]/) ins = i
	for (i = 1; i <= n; i++) { print lines[i]; if (i == ins) print line }
}
' "$FILE" >"$tmp"
cat "$tmp" >"$FILE" # in-place rewrite preserves the inode (Obsidian-friendly)
rm -f "$tmp"
