/* Omarchy Ethereal theme for the wallpaper picker (wallpaper-picker.sh).
 * Standalone theme: loaded with `rofi -theme`, so it replaces rofi's
 * default theme entirely. Matches the waybar floating-islands palette. */

* {
    font: "JetBrainsMono Nerd Font 11";

    bg:         rgba(6,11,30,0.95);
    bg-raised:  rgba(255,255,255,0.06);
    fg:         #ffcead;
    fg-dim:     #6d7db6;
    accent:     #7d82d9;
    accent-dim: rgba(125,130,217,0.18);
    border-col: #ffcead;

    background-color: transparent;
    text-color: @fg;
}

window {
    width: 72%;
    background-color: @bg;
    border: 3px;
    border-color: @border-col;
    border-radius: 12px;
    padding: 12px;
}

mainbox {
    spacing: 10px;
    children: [ inputbar, listview ];
}

inputbar {
    background-color: @bg-raised;
    border-radius: 8px;
    padding: 8px 12px;
    spacing: 8px;
    children: [ prompt, entry ];
}

prompt {
    text-color: @accent;
}

entry {
    text-color: @fg;
    placeholder: "Filter…";
    placeholder-color: @fg-dim;
    cursor: text;
}

listview {
    columns: 3;
    lines: 4;
    spacing: 8px;
    scrollbar: false;
    fixed-height: true;
}

element {
    orientation: vertical;
    padding: 8px;
    border-radius: 10px;
    text-color: @fg-dim;
    cursor: pointer;
}

element selected {
    background-color: @accent-dim;
    text-color: @accent;
}

element-icon {
    size: 6em;
    cursor: inherit;
}

element-text {
    horizontal-align: 0.5;
    text-color: inherit;
    cursor: inherit;
}
