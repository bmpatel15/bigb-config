# Ghostty — Omarchy Ethereal
# Colors live in themes/ethereal; font/window/shader below.

font-family = JetBrainsMono Nerd Font Mono
font-size = 10

theme = ethereal

term = xterm-256color

# Cursor
cursor-style = block
cursor-style-blink = true

# Window (matches existing alacritty padding)
window-padding-x = 14
window-padding-y = 14

# Transparency — do this HERE, not via Hyprland's decoration:active_opacity.
# Compositor opacity alphas the whole window surface including glyphs, so text
# washes into the wallpaper and the window reads as "gone". background-opacity
# only touches the background and leaves glyphs fully opaque.
# Keep hyprland.lua's active_opacity/inactive_opacity at 1.0.
background-opacity = 0.85

# Cells with an explicit background color stay opaque (this is the default;
# stated explicitly so it isn't lost later).
background-opacity-cells = false

# Copy/paste — paired with Hyprland SUPER+C/SUPER+V (-> Ctrl+Insert / Shift+Insert).
# Ghostty's default shift+insert pastes the PRIMARY selection; override it to the
# clipboard so SUPER+V pastes exactly what SUPER+C copied.
keybind = ctrl+insert=copy_to_clipboard
keybind = shift+insert=paste_from_clipboard

confirm-close-surface = false

# Subtle comet-tail cursor trail.
# Ghostty has no native cursor trail; this is a GLSL post-process shader.
# Path is relative to ~/.config/ghostty/. `always` keeps it animating when
# unfocused so the tail doesn't freeze (small CPU cost — drop to `true` to save power).
custom-shader = shaders/cursor_tail.glsl
custom-shader-animation = always
